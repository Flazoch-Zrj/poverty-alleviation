<scroll-view class="page" scroll-y>
  <!-- 家庭头卡 -->
  <view class="family-hero grad-primary">
    <text class="family-name">{{family.householderName || '加载中...'}}</text>
    <view class="family-meta">
      <view class="family-tag">📋 {{family.familyCode || '-'}}</view>
      <view class="family-tag">🏷️ {{family.povertyLevel || '-'}}</view>
    </view>
  </view>

  <!-- 信息卡片 -->
  <view class="card">
    <view class="card-header-row">
      <text class="title-3">📋 家庭信息</text>
      <text class="edit-btn" bindtap="goEdit">✏️ 编辑</text>
    </view>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">👨‍👩‍👧‍👦 人口</text>
        <text class="info-value">{{family.familySize || '-'}} 人</text>
      </view>
      <view class="info-item">
        <text class="info-label">💰 年收入</text>
        <text class="info-value accent">{{incomeText || '-'}} 元</text>
      </view>
      <view class="info-item">
        <text class="info-label">📍 地址</text>
        <text class="info-value" style="font-size:22rpx;">{{family.address || '-'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">🤝 责任人</text>
        <text class="info-value">{{pairInfo ? pairInfo.cadreName : '暂无'}}</text>
      </view>
    </view>
  </view>

  <!-- 家庭成员 -->
  <view class="card">
    <view class="card-header-row">
      <text class="title-3">👨‍👩‍👧‍👦 家庭成员</text>
      <text class="edit-btn" bindtap="goMembers">管理 ›</text>
    </view>
    <view wx:for="{{members}}" wx:key="memberId" class="member-row">
      <view class="member-avatar">{{item.nameInitial || "?"}}</view>
      <view class="member-body">
        <text class="member-name">{{item.name}}</text>
        <text class="member-detail">{{item.relationship}} · {{item.age}}岁</text>
      </view>
      <view class="member-status" wx:if="{{item.healthStatus}}">
        <text class="tag tag-info">{{item.healthStatus}}</text>
      </view>
    </view>
    <view wx:if="{{members.length===0}}" style="text-align:center;color:#94A3B8;font-size:24rpx;padding:30rpx 0;">暂无家庭成员</view>
  </view>

  <view style="height:40rpx;"></view>
</scroll-view>
