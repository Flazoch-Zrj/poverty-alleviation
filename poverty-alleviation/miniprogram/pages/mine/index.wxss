.user-card { text-align:center; padding:60rpx 20rpx 40rpx; color:#fff; border-radius:0 0 32rpx 32rpx; }
.user-avatar { width:100rpx; height:100rpx; border-radius:50%; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; font-size:44rpx; font-weight:700; margin:0 auto 16rpx; }
.user-name { font-size:36rpx; font-weight:700; display:block; }
.user-role { font-size:24rpx; opacity:.8; margin-top:6rpx; display:block; }
.user-cadre { font-size:22rpx; opacity:.7; margin-top:12rpx; display:block; }

.menu-card { background:#fff; border-radius:16rpx; margin:20rpx; overflow:hidden; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.03); }
.menu-item { display:flex; justify-content:space-between; align-items:center; padding:30rpx 24rpx; border-bottom:1rpx solid #F8FAFC; }
.menu-item:last-child { border-bottom:none; }
.menu-left { font-size:28rpx; color:#1E293B; }
.menu-right { font-size:28rpx; color:#CBD5E1; }
