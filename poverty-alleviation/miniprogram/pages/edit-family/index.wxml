<view class="page">
  <view class="form-group"><text class="form-label">户主姓名</text><input class="form-input" model:value="{{form.householderName}}"/></view>
  <view class="form-group"><text class="form-label">家庭地址</text><input class="form-input" model:value="{{form.address}}"/></view>
  <view class="form-group"><text class="form-label">家庭人数</text><input class="form-input" model:value="{{form.familySize}}" type="number"/></view>
  <view class="form-group"><text class="form-label">年收入(元)</text><input class="form-input" model:value="{{form.annualIncome}}" type="digit"/></view>
  <button class="btn-primary" bindtap="handleSubmit" loading="{{loading}}">保存</button>
</view>
