.hero-banner {
  margin: -1rpx -1rpx 0; padding: 48rpx 32rpx 36rpx; color: #fff;
  border-radius: 0 0 32rpx 32rpx; position: relative; overflow: hidden;
}
.hero-banner::after {
  content: ''; position: absolute; right: -40rpx; top: -40rpx;
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.hero-top { display: flex; align-items: center; gap: 20rpx; }
.hero-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 700;
}
.hero-greeting { font-size: 24rpx; opacity: 0.8; display: block; }
.hero-name { font-size: 36rpx; font-weight: 700; display: block; margin-top: 4rpx; }
.hero-meta { display: flex; align-items: center; gap: 12rpx; margin-top: 16rpx; font-size: 24rpx; opacity: 0.9; }
.hero-tag { padding: 4rpx 14rpx; background: rgba(255,255,255,0.2); border-radius: 999rpx; font-size: 20rpx; }

.grid-4 { display: flex; gap: 16rpx; padding: 24rpx 20rpx; margin-top: -20rpx; }
.grid-item { flex: 1; text-align: center; background: #fff; border-radius: 16rpx; padding: 20rpx 8rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.grid-icon { width: 56rpx; height: 56rpx; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; margin: 0 auto 10rpx; }
.grid-label { font-size: 22rpx; color: #64748B; font-weight: 500; }

.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 0 20rpx 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.card-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }

.todo-item { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 0; border-bottom: 1rpx solid #F8FAFC; }
.todo-item:last-child { border-bottom: none; }
.todo-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.todo-dot.high { background: #EF4444; box-shadow: 0 0 8rpx rgba(239,68,68,0.4); }
.todo-dot.medium { background: #F59E0B; }
.todo-dot.low { background: #10B981; }
.todo-body { flex: 1; }
.todo-text { font-size: 26rpx; color: #1E293B; display: block; }
.todo-type { font-size: 22rpx; color: #94A3B8; display: block; margin-top: 2rpx; }

.news-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F8FAFC; }
.news-item:last-child { border-bottom: none; }
.news-left { flex: 1; }
.news-title { font-size: 26rpx; color: #1E293B; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.news-date { font-size: 22rpx; color: #94A3B8; display: block; margin-top: 4rpx; }
.news-arrow { color: #CBD5E1; font-size: 28rpx; flex-shrink: 0; margin-left: 12rpx; }
.empty-hint { text-align: center; color: #94A3B8; font-size: 24rpx; padding: 20rpx; }
