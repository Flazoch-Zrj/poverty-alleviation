<view class="page">
  <view class="page-header">
    <text class="title-1">📢 困难需求</text>
    <view class="btn-primary btn-small" bindtap="goAdd">＋ 发布</view>
  </view>

  <view class="filter-row">
    <view wx:for="{{['全部','待解决','已对接','已完成']}}" wx:key="index"
      class="filter-pill {{activeFilter===index?'active':''}}"
      bindtap="switchTab" data-index="{{index}}">{{item}}</view>
  </view>

  <view wx:for="{{list}}" wx:key="needId" class="need-card card-clickable">
    <view class="need-header">
      <view class="capsule {{[['capsule-pending'],['capsule-pending'],['capsule-active'],['capsule-done']][Number(item.status)] || ''}}">
        {{['待解决','待解决','已对接','已完成'][Number(item.status)] || '未知'}}
      </view>
      <text class="body-tiny">{{item.needType}}</text>
    </view>
    <text class="need-title title-3" style="margin:12rpx 0 8rpx;">{{item.title}}</text>
    <text class="need-desc body-small">{{item.description}}</text>
    <view class="need-footer">
      <text class="body-tiny">🎯 {{item.fmtTarget || '-'}} 元</text>
      <text class="body-tiny" wx:if="{{item.targetAmount > 0}}">已筹 {{item.actualAmount || 0}} 元</text>
    </view>
    <view class="progress" wx:if="{{item.targetAmount > 0}}" style="margin-top:12rpx;">
      <view class="progress-fill grad-accent" style="width:{{item.progressPct}}%"></view>
    </view>
  </view>

  <view wx:if="{{list.length===0}}" class="empty-box">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无需求</text>
  </view>

  <view style="height:40rpx;"></view>
</view>
