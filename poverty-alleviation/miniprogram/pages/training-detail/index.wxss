.page { background:#F8FAFC; min-height:100vh; padding:20rpx; }
.card { background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:20rpx; }
.t-title { font-size:34rpx; font-weight:700; color:#1E293B; display:block; margin-bottom:16rpx; }
.t-row { display:flex; justify-content:space-between; font-size:24rpx; color:#64748B; margin-bottom:8rpx; }
.t-section { margin-top:20rpx; }
.t-section-title { font-size:26rpx; font-weight:600; display:block; margin-bottom:8rpx; }
.t-desc { font-size:24rpx; color:#64748B; line-height:1.6; }
.btn-primary { width:100%; height:88rpx; background:linear-gradient(135deg,#0A2647,#2D7A9B); color:#fff; border-radius:12rpx; font-size:30rpx; line-height:88rpx; margin-top:20rpx; }
.btn-disabled { width:100%; height:88rpx; background:#E2E8F0; color:#94A3B8; border-radius:12rpx; font-size:30rpx; line-height:88rpx; margin-top:20rpx; }
.card-header { font-size:28rpx; font-weight:600; margin-bottom:12rpx; }
.enroll-item { display:flex; justify-content:space-between; padding:12rpx 0; font-size:24rpx; color:#64748B; border-bottom:1rpx solid #F1F5F9; }
.status-tag { padding:2rpx 12rpx; border-radius:6rpx; background:#FEF3C7; color:#D97706; font-size:22rpx; }
.empty-text { text-align:center; color:#94A3B8; padding:20rpx; font-size:24rpx; }
