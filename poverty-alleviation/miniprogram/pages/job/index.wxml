<view class="page">
  <view class="page-header">
    <text class="title-1">💼 就业岗位</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索岗位名称/公司" model:value="{{keyword}}" confirm-type="search" bindconfirm="loadData" />
  </view>

  <!-- 岗位列表 -->
  <view wx:for="{{list}}" wx:key="jobId" class="job-card card-clickable" data-id="{{item.jobId}}" bindtap="goDetail">
    <view class="job-top">
      <view class="job-icon-box grad-primary">💼</view>
      <view class="job-info">
        <text class="job-title">{{item.title}}</text>
        <text class="job-company">🏢 {{item.company || '未知'}}</text>
      </view>
      <view class="job-salary">{{item.salaryRange || '面议'}}</view>
    </view>
    <view class="job-bottom">
      <text class="job-location">📍 {{item.workplace || ''}}</text>
      <text class="job-contact">📞 {{item.contact || ''}}</text>
    </view>
  </view>

  <view wx:if="{{list.length===0}}" class="empty-box">
    <text class="empty-icon">💼</text>
    <text class="empty-text">暂无岗位</text>
  </view>

  <view style="height:40rpx;"></view>
</view>
