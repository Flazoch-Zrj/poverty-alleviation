.page { background:#F0F2F5; min-height:100vh; padding:24rpx; }
.page-header { margin-bottom:20rpx; }

.search-box { display:flex; align-items:center; gap:12rpx; background:#fff; border-radius:14rpx; padding:0 20rpx; height:80rpx; margin-bottom:20rpx; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.03); }
.search-icon { font-size:28rpx; flex-shrink:0; }
.search-input { flex:1; font-size:26rpx; height:100%; }

.job-card { background:#fff; border-radius:16rpx; padding:24rpx; margin-bottom:14rpx; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.03); }
.job-top { display:flex; align-items:center; gap:14rpx; }
.job-icon-box { width:48rpx; height:48rpx; border-radius:12rpx; display:flex; align-items:center; justify-content:center; font-size:24rpx; flex-shrink:0; }
.job-info { flex:1; min-width:0; }
.job-title { font-size:28rpx; font-weight:600; color:#1E293B; display:block; }
.job-company { font-size:24rpx; color:#64748B; display:block; margin-top:4rpx; }
.job-salary { font-size:28rpx; font-weight:700; color:#F97316; flex-shrink:0; }
.job-bottom { display:flex; gap:20rpx; margin-top:12rpx; padding-top:12rpx; border-top:1rpx solid #F8FAFC; }
.job-location, .job-contact { font-size:22rpx; color:#94A3B8; }

.empty-box { text-align:center; padding:100rpx 0; }
.empty-icon { font-size:64rpx; display:block; margin-bottom:16rpx; }
.empty-text { font-size:28rpx; color:#94A3B8; }
